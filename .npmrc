# The `packageManager` field in package.json pins pnpm 11.9.0 so CI
# (pnpm/action-setup) installs a known-good version. Locally, however, we do NOT
# want pnpm to auto-download/switch to that exact version on every command: that
# path goes through corepack, and many machines have a corepack with stale npm
# signing keys ("Cannot find matching keyid"). Any recent pnpm (>= 9) reads this
# repo's lockfile correctly, so just use whatever pnpm is installed.
manage-package-manager-versions=false
